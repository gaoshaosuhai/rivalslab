---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE_NAME, CONTACT_EMAIL } from '@/consts';

const effectiveDate = '2026-05-09';
---

<BaseLayout
  title="Terms of Use"
  description={`Terms of use for ${SITE_NAME}.`}
>
  <section class="container-narrow py-12 md:py-16 max-w-3xl">
    <h1 class="display-tight text-4xl md:text-5xl uppercase tracking-tight">Terms of Use</h1>
    <p class="mt-2 text-xs text-[color:var(--fg-dim)] uppercase tracking-widest">
      Effective {effectiveDate}
    </p>

    <h2 class="display text-2xl uppercase tracking-tight mt-10">Independent fan tool</h2>
    <p class="mt-3 text-[color:var(--fg-muted)] leading-relaxed">
      {SITE_NAME} is an independent fan tool for Marvel Rivals. We are not affiliated with, endorsed by, or sponsored
      by NetEase Games or Marvel Games. Marvel Rivals and all hero, ability, and map names are trademarks of their
      respective owners.
    </p>

    <h2 class="display text-2xl uppercase tracking-tight mt-10">Use of the site</h2>
    <p class="mt-3 text-[color:var(--fg-muted)] leading-relaxed">
      The site is provided as-is for informational purposes. Tools, calculators, and recommendations are offered
      without warranty. Use the site at your own discretion; no part of it is intended to enable cheating, account
      trading, terms-of-service violations, or any other prohibited gameplay.
    </p>

    <h2 class="display text-2xl uppercase tracking-tight mt-10">Liability</h2>
    <p class="mt-3 text-[color:var(--fg-muted)] leading-relaxed">
      Information may be incomplete or out of date. We aim to bump the data-reviewed date in the footer regularly,
      but make no guarantees. We are not liable for outcomes resulting from the use of any tool or recommendation
      on this site.
    </p>

    <h2 class="display text-2xl uppercase tracking-tight mt-10">Content rights</h2>
    <p class="mt-3 text-[color:var(--fg-muted)] leading-relaxed">
      Original written content (tier judgments, guides, calculator math) is the work of {SITE_NAME}'s operators and
      may be cited with attribution. Game-related screenshots, sprite imagery, and item data displayed on the site
      belong to NetEase Games and Marvel Games and are used here under fair-use fan-tool conventions.
    </p>

    <h2 class="display text-2xl uppercase tracking-tight mt-10">Contact</h2>
    <p class="mt-3 text-[color:var(--fg-muted)] leading-relaxed">
      Questions or takedown requests: <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>.
    </p>

    <h2 class="display text-2xl uppercase tracking-tight mt-10">Changes</h2>
    <p class="mt-3 text-[color:var(--fg-muted)] leading-relaxed">
      Terms may change as the site evolves. The effective date above reflects the current version.
    </p>
  </section>
</BaseLayout>
