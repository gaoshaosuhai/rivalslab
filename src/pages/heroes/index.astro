---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/SectionHero.astro';
import EntitySchema from '@/components/EntitySchema.astro';
import { HEROES, ROLES_ORDER, heroesByRole, roleClass } from '@/data/heroes';
import HeroGlyph from '@/components/HeroGlyph.astro';
---

<BaseLayout
  title="All Marvel Rivals heroes — guide & tier"
  description={`Browse all ${HEROES.length} Marvel Rivals heroes by role. Counters, team-ups, best maps, current tier.`}
>
  <EntitySchema
    articleType="CollectionPage"
    title="All Marvel Rivals heroes"
    description={`Browse all ${HEROES.length} Marvel Rivals heroes by role. Counters, team-ups, best maps, current tier.`}
    path="/heroes/"
    breadcrumbs={[
      { name: 'Home', path: '/' },
      { name: 'Heroes' },
    ]}
  />
  <SectionHero
    image="/images/ss-03.jpg"
    alt="Marvel Rivals roster — all 49 heroes"
    focus="center"
    tint="cosmic"
    variant="compact"
  >
    <div class="text-xs uppercase tracking-widest text-[color:var(--fg-muted)] mb-3 [text-shadow:0_1px_8px_rgba(0,0,0,0.6)]">
      Tools / <span class="text-[color:var(--fg)]">Heroes</span>
    </div>
    <h1 class="display-tight text-4xl md:text-6xl uppercase tracking-tight [text-shadow:0_2px_25px_rgba(0,0,0,0.55)]">Heroes</h1>
    <p class="mt-3 text-lg text-[color:var(--fg)] max-w-3xl leading-relaxed [text-shadow:0_1px_15px_rgba(0,0,0,0.6)]">
      All {HEROES.length} active Marvel Rivals heroes — counters, team-ups, best maps, current tier.
    </p>
  </SectionHero>

  {ROLES_ORDER.map((role) => {
    const list = heroesByRole(role);
    if (list.length === 0) return null;
    return (
      <section class="container-wide pb-10">
        <h2 class={`display text-2xl md:text-3xl uppercase tracking-tight mb-4 ${roleClass(role)}`}>
          {role} <span class="text-[color:var(--fg-dim)] text-base">({list.length})</span>
        </h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
          {list.map((h) => (
            <a href={`/heroes/${h.id}/`} class="card p-4 hover:border-[color:color-mix(in_oklab,var(--accent)_45%,transparent)] transition-colors group flex gap-3">
              <HeroGlyph hero={h} size={56} />
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-1.5">
                  <span class={`chip ${h.tier === 'S' ? 'chip-warn' : 'chip-accent'}`}>{h.tier}</span>
                  <span class="text-[10px] text-[color:var(--fg-dim)] uppercase tracking-widest">{h.difficulty}</span>
                </div>
                <div class="display text-lg uppercase text-[color:var(--fg)] group-hover:text-[color:var(--accent)] leading-tight">
                  {h.name}
                </div>
                <p class="text-xs text-[color:var(--fg-muted)] mt-1.5 line-clamp-2">{h.blurb}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>
