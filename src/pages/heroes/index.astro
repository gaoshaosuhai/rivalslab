---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { HEROES, ROLES_ORDER, heroesByRole, roleClass } from '@/data/heroes';
---

<BaseLayout
  title="All Marvel Rivals heroes — guide & tier"
  description={`Browse all ${HEROES.length} Marvel Rivals heroes by role. Counters, team-ups, best maps, current tier.`}
>
  <section class="container-wide pt-10 pb-6">
    <div class="text-xs uppercase tracking-widest text-[color:var(--fg-dim)] mb-3">
      Tools / <span class="text-[color:var(--fg-muted)]">Heroes</span>
    </div>
    <h1 class="display-tight text-4xl md:text-6xl uppercase tracking-tight">Heroes</h1>
    <p class="mt-3 text-lg text-[color:var(--fg-muted)] max-w-3xl leading-relaxed">
      All {HEROES.length} active Marvel Rivals heroes — counters, team-ups, best maps, current tier.
    </p>
  </section>

  {ROLES_ORDER.map((role) => {
    const list = heroesByRole(role);
    if (list.length === 0) return null;
    return (
      <section class="container-wide pb-10">
        <h2 class={`display text-2xl md:text-3xl uppercase tracking-tight mb-4 ${roleClass(role)}`}>
          {role} <span class="text-[color:var(--fg-dim)] text-base">({list.length})</span>
        </h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
          {list.map((h) => (
            <a href={`/heroes/${h.id}/`} class="card p-4 hover:border-[color:color-mix(in_oklab,var(--accent)_45%,transparent)] transition-colors group">
              <div class="flex items-center gap-2 mb-2">
                <span class={`chip ${h.tier === 'S' ? 'chip-warn' : 'chip-accent'}`}>{h.tier}</span>
                <span class="text-xs text-[color:var(--fg-dim)] uppercase">{h.difficulty}</span>
              </div>
              <div class="display text-lg uppercase text-[color:var(--fg)] group-hover:text-[color:var(--accent)]">
                {h.name}
              </div>
              <p class="text-xs text-[color:var(--fg-muted)] mt-2 line-clamp-3">{h.blurb}</p>
            </a>
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>
