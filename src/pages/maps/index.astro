---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/SectionHero.astro';
import { MAPS, MODES_ORDER, mapsByMode } from '@/data/maps';
---

<BaseLayout
  title="Maps — best heroes for each Marvel Rivals map"
  description={`Per-map hero recommendations for all ${MAPS.length} active Marvel Rivals competitive maps. Convoy, Domination, Convergence.`}
>
  <SectionHero
    image="/images/ss-05.jpg"
    alt="Marvel Rivals map environment — competitive arena"
    focus="center"
    tint="panel"
    variant="compact"
  >
    <div class="text-xs uppercase tracking-widest text-[color:var(--fg-muted)] mb-3 [text-shadow:0_1px_8px_rgba(0,0,0,0.6)]">
      Tools / <span class="text-[color:var(--fg)]">Maps</span>
    </div>
    <h1 class="display-tight text-4xl md:text-6xl uppercase tracking-tight [text-shadow:0_2px_25px_rgba(0,0,0,0.55)]">
      Map <span class="text-[color:var(--accent)]">Picks</span>
    </h1>
    <p class="mt-3 text-lg text-[color:var(--fg)] max-w-3xl leading-relaxed [text-shadow:0_1px_15px_rgba(0,0,0,0.6)]">
      Every active Marvel Rivals competitive map with role lean, top heroes, and team-up recommendations.
    </p>
  </SectionHero>

  {MODES_ORDER.map((mode) => {
    const list = mapsByMode(mode);
    if (list.length === 0) return null;
    return (
      <section class="container-wide pb-10">
        <div class="flex items-end justify-between mb-4">
          <h2 class="display text-2xl md:text-3xl uppercase tracking-tight">
            {mode} <span class="text-[color:var(--fg-dim)] text-base">({list.length})</span>
          </h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {list.map((m) => (
            <a href={`/maps/${m.id}/`} class="card-panel p-4 hover:border-[color:color-mix(in_oklab,var(--accent)_45%,transparent)] transition-colors group">
              <div class="flex items-center gap-2 mb-2">
                <span class="chip chip-accent">{m.mode}</span>
              </div>
              <div class="display text-xl uppercase text-[color:var(--fg)] group-hover:text-[color:var(--accent)]">
                {m.name}
              </div>
              <p class="text-sm text-[color:var(--fg-muted)] mt-2 line-clamp-2">{m.flavor}</p>
              <div class="mt-3 text-xs text-[color:var(--fg-dim)]">
                Top: {m.topHeroes.slice(0, 3).join(' · ')}
              </div>
            </a>
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>
