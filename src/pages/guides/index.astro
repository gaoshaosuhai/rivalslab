---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EntitySchema from '@/components/EntitySchema.astro';
import SectionHero from '@/components/SectionHero.astro';

const guides: Array<{ slug: string; title: string; blurb: string; tag: string }> = [
  {
    slug: 'getting-started',
    title: 'New player guide — Marvel Rivals',
    blurb: 'Pick your role, your first hero, and what to ignore for your first 20 matches.',
    tag: 'Beginner',
  },
  {
    slug: 'season-8-meta',
    title: 'Season 8 meta forecast',
    blurb: 'Cyclops and Moon Girl & Devil Dinosaur drop on May 15. Tier shifts, prep checklist, and Team-Ups to learn first.',
    tag: 'Seasonal',
  },
  {
    slug: 'best-heroes-by-rank',
    title: 'Best heroes by rank — Bronze to Celestial',
    blurb: 'Rank-aware hero picks. The right hero in Plat is wrong in Diamond. Here\'s the per-tier shortlist.',
    tag: 'Climb',
  },
];
---

<BaseLayout
  title="Marvel Rivals guides"
  description="Long-form Marvel Rivals guides — beginner playbook, season forecast, rank-aware hero picks. Written in Diamond-III voice."
>
  <EntitySchema
    articleType="CollectionPage"
    title="Marvel Rivals guides"
    description="Long-form Marvel Rivals guides — beginner playbook, season forecast, rank-aware hero picks. Written in Diamond-III voice."
    path="/guides/"
    breadcrumbs={[
      { name: 'Home', path: '/' },
      { name: 'Guides' },
    ]}
  />
  <SectionHero
    image="/images/ss-01.jpg"
    alt="Marvel Rivals heroes in action — guide content"
    focus="center"
    tint="cosmic"
    variant="compact"
  >
    <div class="text-xs uppercase tracking-widest text-[color:var(--fg-muted)] mb-3 [text-shadow:0_1px_8px_rgba(0,0,0,0.6)]">
      <span class="text-[color:var(--fg)]">Guides</span>
    </div>
    <h1 class="display-tight text-4xl md:text-6xl uppercase tracking-tight [text-shadow:0_2px_25px_rgba(0,0,0,0.55)]">Guides</h1>
    <p class="mt-3 text-lg text-[color:var(--fg)] max-w-3xl leading-relaxed [text-shadow:0_1px_15px_rgba(0,0,0,0.6)]">
      Practical Marvel Rivals long-form. Written for the queue-anxious ranked grinder, not for the wiki bot.
    </p>
  </SectionHero>

  <section class="container-wide pb-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        guides.map((g) => (
          <a href={`/guides/${g.slug}/`} class="card-panel p-5 hover:border-[color:color-mix(in_oklab,var(--accent)_45%,transparent)] transition-colors block">
            <span class="chip chip-accent">{g.tag}</span>
            <div class="display text-xl uppercase tracking-tight mt-3 text-[color:var(--fg)]">{g.title}</div>
            <p class="text-sm text-[color:var(--fg-muted)] mt-2 leading-snug">{g.blurb}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
