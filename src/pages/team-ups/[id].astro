---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EntitySchema from '@/components/EntitySchema.astro';
import { TEAM_UPS, type TeamUp } from '@/data/team-ups';
import { heroById, roleClass, heroPortraitUrl } from '@/data/heroes';
import { mapById } from '@/data/maps';
import HeroGlyph from '@/components/HeroGlyph.astro';

export async function getStaticPaths() {
  return TEAM_UPS.map((t) => ({ params: { id: t.id }, props: { teamUp: t } }));
}

interface Props { teamUp: TeamUp; }
const { teamUp } = Astro.props;

const anchor = heroById(teamUp.anchor);
const secondaries = teamUp.secondaries.map((id) => heroById(id)).filter(Boolean);
const bestMaps = (teamUp.bestMaps ?? []).map((id) => mapById(id)).filter(Boolean);
const relatedTeamUps = TEAM_UPS
  .filter((t) => t.id !== teamUp.id && (
    t.anchor === teamUp.anchor ||
    teamUp.secondaries.some((s) => t.anchor === s || t.secondaries.includes(s)) ||
    t.tier === teamUp.tier
  ))
  .slice(0, 4);

const tierWord = { S: 'meta-defining', A: 'strong', B: 'situational', C: 'niche' }[teamUp.tier];
const description = `${teamUp.name} — ${anchor?.name} anchor team-up in Marvel Rivals. ${teamUp.ability}`;
const ogImage = anchor ? (heroPortraitUrl(anchor.id) ?? '/og-default.svg') : '/og-default.svg';
---

<BaseLayout title={`${teamUp.name} — Team-Up guide`} description={description} image={ogImage}>
  <EntitySchema
    articleType="Article"
    title={`${teamUp.name} — Marvel Rivals Team-Up guide`}
    description={description}
    path={`/team-ups/${teamUp.id}/`}
    image={ogImage}
    breadcrumbs={[
      { name: 'Home', path: '/' },
      { name: 'Team-Ups', path: '/team-ups/' },
      { name: teamUp.name },
    ]}
  />
  <article class="container-narrow py-10 md:py-14">
    <div class="text-xs uppercase tracking-widest text-[color:var(--fg-dim)] mb-3">
      <a href="/team-ups/" class="hover:text-[color:var(--accent)]">Team-Ups</a> /
      <span class="text-[color:var(--fg-muted)]">{teamUp.name}</span>
    </div>

    <div class="flex items-center gap-3 mb-4">
      <span class={`chip ${teamUp.tier === 'S' ? 'chip-warn' : 'chip-accent'}`}>Tier {teamUp.tier}</span>
      <span class="chip chip-muted">{teamUp.introduced}</span>
    </div>

    <h1 class="display-tight text-5xl md:text-6xl uppercase tracking-tight">{teamUp.name}</h1>
    <p class="mt-3 text-lg text-[color:var(--fg-muted)]">{teamUp.ability}</p>

    <div class="mt-8 grid md:grid-cols-3 gap-4">
      {anchor && (
        <a href={`/heroes/${anchor.id}/`} class="card-panel p-4 hover:border-[color:color-mix(in_oklab,var(--accent)_45%,transparent)] transition-colors flex gap-3">
          <HeroGlyph hero={anchor} size={64} />
          <div class="min-w-0 flex-1">
            <div class="text-xs uppercase tracking-widest text-[color:var(--accent)] font-semibold">Anchor</div>
            <div class="display text-xl uppercase mt-1 text-[color:var(--fg)] leading-tight">{anchor.name}</div>
            <div class={`text-sm mt-1 ${roleClass(anchor.role)}`}>{anchor.role}</div>
            <p class="text-xs text-[color:var(--fg-muted)] mt-2 leading-snug line-clamp-2">{anchor.blurb}</p>
          </div>
        </a>
      )}
      {secondaries.map((h) => h && (
        <a href={`/heroes/${h.id}/`} class="card p-4 hover:border-[color:color-mix(in_oklab,var(--accent)_45%,transparent)] transition-colors flex gap-3">
          <HeroGlyph hero={h} size={64} />
          <div class="min-w-0 flex-1">
            <div class="text-xs uppercase tracking-widest text-[color:var(--fg-dim)] font-semibold">Secondary</div>
            <div class="display text-xl uppercase mt-1 text-[color:var(--fg)] leading-tight">{h.name}</div>
            <div class={`text-sm mt-1 ${roleClass(h.role)}`}>{h.role}</div>
            <p class="text-xs text-[color:var(--fg-muted)] mt-2 leading-snug line-clamp-2">{h.blurb}</p>
          </div>
        </a>
      ))}
    </div>

    <section class="mt-10">
      <h2 class="display text-2xl uppercase tracking-tight mb-3">How to run it</h2>
      <p class="text-[color:var(--fg)] leading-relaxed">{teamUp.blurb}</p>
    </section>

    {bestMaps.length > 0 && (
      <section class="mt-10">
        <h2 class="display text-2xl uppercase tracking-tight mb-3">Best maps</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {bestMaps.map((m) => m && (
            <a href={`/maps/${m.id}/`} class="card p-4 hover:border-[color:color-mix(in_oklab,var(--accent)_45%,transparent)] transition-colors">
              <div class="display text-lg uppercase text-[color:var(--fg)]">{m.name}</div>
              <div class="text-xs uppercase tracking-widest text-[color:var(--fg-dim)] mt-1">{m.mode}</div>
              <p class="text-sm text-[color:var(--fg-muted)] mt-2">{m.notes}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mt-10 card p-6">
      <h2 class="display text-xl uppercase tracking-tight mb-2">When to lock it in</h2>
      <p class="text-[color:var(--fg-muted)] leading-relaxed">
        {teamUp.name} is a <strong class="text-[color:var(--fg)]">{tierWord}</strong> team-up
        as of the latest snapshot. Lock the anchor early in the draft phase if your team
        is committing to {anchor?.role.toLowerCase()} sustain — without {anchor?.name}, the synergy doesn't activate.
      </p>
    </section>

    {relatedTeamUps.length > 0 && (
      <section class="mt-10">
        <h2 class="display text-2xl uppercase tracking-tight mb-4">Related Team-Ups</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {relatedTeamUps.map((t) => {
            const ta = heroById(t.anchor);
            return (
              <a href={`/team-ups/${t.id}/`} class="card p-4 hover:border-[color:color-mix(in_oklab,var(--accent)_45%,transparent)] transition-colors">
                <div class="flex items-start gap-2 mb-2">
                  <span class={`chip ${t.tier === 'S' ? 'chip-warn' : 'chip-accent'}`}>{t.tier}</span>
                  <span class="text-xs text-[color:var(--fg-dim)] uppercase tracking-widest">{t.introduced}</span>
                </div>
                <div class="display text-lg uppercase tracking-tight text-[color:var(--fg)]">{t.name}</div>
                <div class="text-xs text-[color:var(--fg-dim)] mt-1">
                  <span class="text-[color:var(--accent)]">{ta?.name ?? t.anchor}</span>
                </div>
                <p class="text-sm text-[color:var(--fg-muted)] mt-2 line-clamp-2">{t.ability}</p>
              </a>
            );
          })}
        </div>
        <p class="mt-4 text-sm text-[color:var(--fg-muted)]">
          Browse all <a href="/team-ups/" class="text-[color:var(--accent)] hover:text-[color:var(--accent-soft)]">{TEAM_UPS.length} active Team-Ups →</a>
        </p>
      </section>
    )}
  </article>
</BaseLayout>
