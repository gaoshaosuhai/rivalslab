---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE_NAME } from '@/consts';
---

<BaseLayout
  title="Page not found"
  description="That page doesn't exist."
  noindex={true}
>
  <section class="container-narrow py-20 md:py-32 text-center">
    <div class="display text-7xl md:text-9xl text-[color:var(--accent)] tracking-tight">404</div>
    <h1 class="mt-4 display-tight text-3xl md:text-4xl uppercase tracking-tight">Hero not found</h1>
    <p class="mt-3 text-[color:var(--fg-muted)] leading-relaxed max-w-md mx-auto">
      That page doesn't exist on {SITE_NAME}. Maybe it moved with a patch, maybe it never shipped.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center gap-2 px-4 py-2.5 rounded-md bg-[color:var(--accent)] text-[color:var(--color-panel-900)] font-semibold hover:bg-[color:var(--accent-soft)] transition-colors"
      >
        Back to home
      </a>
      <a
        href="/team-ups/"
        class="inline-flex items-center gap-2 px-4 py-2.5 rounded-md border border-[color:var(--border)] text-[color:var(--fg)] hover:border-[color:color-mix(in_oklab,var(--accent)_60%,transparent)] transition-colors"
      >
        Team-Up Explorer
      </a>
    </div>
  </section>
</BaseLayout>
